{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_FORK_SUBAGENT": "1",
    "CLAUDE_CODE_ENABLE_PROMPT_SUGGESTION": "true",
    "CLAUDE_CODE_TMUX_TRUECOLOR": "1",
    "ENABLE_TOOL_SEARCH": "true",
    "CLAUDE_CODE_ENABLE_AWAY_SUMMARY": "1",
    "X_CLAUDE_CODE_NO_FLICKER": "1"
  },
  "permissions": {
    "allow": [],
    "deny": [
      "Bash(rm -rf /:*)",
      "Read(~/.zshrc)",
      "Read(~/.bashrc)",
      "Read(~/.bash_profile)",
      "Read(~/.profile)",
      "Read(~/.secrets)",
      "Read(.env)",
      "Read(~/.ssh/*)",
      "Read(/etc/shadow)",
      "Read(/etc/passwd)",
      "Write(/etc/*)",
      "Write(/bin/*)",
      "Write(/usr/bin/*)",
      "Write(/sbin/*)",
      "Write(/usr/sbin/*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/skills/wait-for-pr-comments/detect-pr-push.sh",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "awaySummaryEnabled": true,
  "effortLevel": "xhigh",
  "showThinkingSummaries": true,
  "verbose": false,
  "teammateMode": "auto",
  "agentPushNotifEnabled": true,
  "voiceEnabled": true
}
