{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {},
  "permissions": {
    "allow": [],
    "deny": [
      "Bash(rm -rf /:*)",
      "Read(~/.zshrc)",
      "Read(~/.bashrc)",
      "Read(~/.bash_profile)",
      "Read(~/.profile)",
      "Read(~/.secrets)",
      "Read(.env)",
      "Read(~/.ssh/*)",
      "Read(/etc/shadow)",
      "Read(/etc/passwd)",
      "Write(/etc/*)",
      "Write(/bin/*)",
      "Write(/usr/bin/*)",
      "Write(/sbin/*)",
      "Write(/usr/sbin/*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/skills/wait-for-pr-comments/detect-pr-push.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
