{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "Bash(cat:*)",
      "Bash(cp:*)",
      "Bash(deno check:*)",
      "Bash(deno task:*)",
      "Bash(deno test:*)",
      "Bash(df:*)",
      "Bash(echo:*)",
      "Bash(eslint:*)",
      "Bash(find:*)",
      "Bash(free:*)",
      "Bash(git add:*)",
      "Bash(git branch:*)",
      "Bash(git check-ignore:*)",
      "Bash(git init:*)",
      "Bash(git log:*)",
      "Bash(git pull:*)",
      "Bash(git status:*)",
      "Bash(grep:*)",
      "Bash(head:*)",
      "Bash(jq:*)",
      "Bash(ls:*)",
      "Bash(mkdir:*)",
      "Bash(npm:*)",
      "Bash(pnpm:*)",
      "Bash(prettier:*)",
      "Bash(rg:*)",
      "Bash(stat:*)",
      "Bash(tail:*)",
      "Bash(touch:*)",
      "Bash(uname:*)",
      "Bash(uv run:*)",
      "mcp__context7__get-library-docs",
      "mcp__context7__resolve-library-id",
      "mcp__ide__getDiagnostics",
      "mcp__memory__read_graph",
      "mcp__memory__search_nodes",
      "mcp__memory__create_entities",
      "WebFetch(domain:openai.com)",
      "WebFetch(domain:docs.anthropic.com)",
      "WebSearch"
    ],
    "deny": [
      "Bash(rm -rf /:*)",
      "Read(~/.zshrc)",
      "Read(~/.bashrc)",
      "Read(~/.bash_profile)",
      "Read(~/.profile)",
      "Read(~/.secrets)",
      "Read(.env)",
      "Read(~/.ssh/*)",
      "Read(/etc/shadow)",
      "Read(/etc/passwd)",
      "Write(/etc/*)",
      "Write(/bin/*)",
      "Write(/usr/bin/*)",
      "Write(/sbin/*)",
      "Write(/usr/sbin/*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/skills/wait-for-pr-comments/detect-pr-push.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
